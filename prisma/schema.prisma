// Sub Tracker data model — see docs/HLD.md §2
// Postgres (Neon) for both local dev and Vercel. Set DATABASE_URL to your Neon
// connection string in .env locally and in Vercel's env vars. Schema is synced
// with `prisma db push` (see npm run db:push) — no migration files to manage.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Upload {
  id               String        @id @default(cuid())
  fileName         String
  bankGuess        String?
  importedAt       DateTime      @default(now())
  transactionCount Int           @default(0)
  transactions     Transaction[]
}

model Transaction {
  id             String    @id @default(cuid())
  uploadId       String
  upload         Upload    @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  date           DateTime
  amount         Decimal // spend normalized to a positive number
  rawDescription String
  dedupeHash     String    @unique // sha256(date|amount|rawDescription)
  merchantId     String?
  merchant       Merchant? @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([date])
}

model Merchant {
  id                    String         @id @default(cuid())
  rawPattern            String         @unique // grouping key (normalized description prefix)
  normalizedName        String
  description           String
  category              String // entertainment | utilities | software | telecom | ...
  isSubscriptionService Boolean
  analyzedAt            DateTime       @default(now())
  transactions          Transaction[]
  subscriptions         Subscription[]
}

model Subscription {
  id                  String   @id @default(cuid())
  merchantId          String
  merchant            Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  amount              Decimal // most recent charge amount
  cadence             String // weekly | monthly | yearly
  firstSeen           DateTime
  lastCharged         DateTime
  nextBillingEstimate DateTime
  status              String   @default("active") // active | cancelled | rejected
  isManual            Boolean  @default(false)
  note                String?

  @@index([merchantId])
  @@index([status])
}

model Insight {
  id          String   @id @default(cuid())
  month       String   @unique // "2026-07"
  content     String // Gemini-generated markdown
  generatedAt DateTime @default(now())
}
