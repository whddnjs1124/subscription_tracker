// Sub Tracker data model — see docs/HLD.md §2
// Postgres (Neon) for both local dev and Vercel. Set DATABASE_URL to your Neon
// connection string in .env locally and in Vercel's env vars. Schema is synced
// with `prisma db push` (see npm run db:push) — no migration files to manage.
//
// Multi-user: every row is owned by a User. All queries filter by userId, and
// the dedupe/cache uniques are per-user (two users can have the same charge or
// merchant pattern). Auth is email+password via Auth.js (see auth.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String
  createdAt     DateTime       @default(now())
  uploads       Upload[]
  transactions  Transaction[]
  merchants     Merchant[]
  subscriptions Subscription[]
  insights      Insight[]
}

model Upload {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName         String
  bankGuess        String?
  importedAt       DateTime      @default(now())
  transactionCount Int           @default(0)
  transactions     Transaction[]

  @@index([userId])
}

model Transaction {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadId       String
  upload         Upload    @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  date           DateTime
  amount         Decimal // spend normalized to a positive number
  rawDescription String
  dedupeHash     String // sha256(date|amount|rawDescription)
  merchantId     String?
  merchant       Merchant? @relation(fields: [merchantId], references: [id])

  @@unique([userId, dedupeHash]) // re-uploading the same file is a no-op, per user
  @@index([merchantId])
  @@index([userId])
  @@index([date])
}

model Merchant {
  id                    String         @id @default(cuid())
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawPattern            String // grouping key (normalized description prefix)
  normalizedName        String
  description           String
  category              String // entertainment | utilities | software | telecom | ...
  isSubscriptionService Boolean
  analyzedAt            DateTime       @default(now())
  transactions          Transaction[]
  subscriptions         Subscription[]

  @@unique([userId, rawPattern]) // merchant cache is per-user (avoids leaking descriptors)
  @@index([userId])
}

model Subscription {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchantId          String
  merchant            Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  amount              Decimal // most recent charge amount
  cadence             String // weekly | monthly | yearly
  firstSeen           DateTime
  lastCharged         DateTime
  nextBillingEstimate DateTime
  // Status values are split by who may set them: `stale` is system-set only
  // (auto-detected inactivity, see lib/lifecycle.ts) and `cancelled` is
  // user-set only. That split is what keeps "it stopped charging" apart from
  // "I cancelled it" — detection never writes `cancelled`, PATCH never
  // accepts `stale`.
  status              String   @default("active") // active | stale | cancelled | rejected
  // Set once the user edits amount/cadence/nextBillingEstimate; re-detection
  // must not overwrite those fields, or every import would undo the edit.
  userEdited          Boolean  @default(false)
  isManual            Boolean  @default(false)
  note                String?

  @@index([userId])
  @@index([merchantId])
  @@index([status])
}

// Throttles credential guessing and signup spam. This lives in the database
// rather than in memory because the app runs serverless on Vercel: an
// in-process counter would reset on every cold start and be per-instance, so
// it would throttle almost nothing.
model RateLimit {
  key         String   @id // "login:email:a@b.c" | "login:ip:1.2.3.4" | "signup:ip:1.2.3.4"
  count       Int      @default(0)
  windowStart DateTime @default(now())

  @@index([windowStart]) // for pruning expired rows
}

model Insight {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month       String // "2026-07"
  content     String // Gemini-generated markdown
  generatedAt DateTime @default(now())

  @@unique([userId, month])
  @@index([userId])
}
